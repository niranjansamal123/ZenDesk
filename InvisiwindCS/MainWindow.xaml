<Window x:Class="InvisiwindCS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Invisiwind" Height="560" Width="340"
        MinHeight="400" MinWidth="300"
        Background="#1E1E1E" Foreground="White"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        WindowStyle="None"
        Cursor="Arrow"
        Activated="Window_Activated"
        Deactivated="Window_Deactivated">


    <Window.Resources>
        <Style TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,3"/>
        </Style>
    </Window.Resources>

    <Grid>

        <!-- ── FOCUSED VIEW ── -->
        <Grid x:Name="FullView" Visibility="Visible">

            <!-- Title bar -->
            <Grid Height="32" VerticalAlignment="Top"
                  Background="#2a2a2a"
                  MouseLeftButtonDown="TitleBar_MouseDown">
                <StackPanel Orientation="Horizontal"
            VerticalAlignment="Center"
            Margin="10,0">

                    <!-- ICO Image -->
                    <Image Source="ZenDesk.ico"
           Width="16" Height="16"
           VerticalAlignment="Center"
           RenderOptions.BitmapScalingMode="HighQuality"
           Margin="0,0,6,0"/>

                    <!-- App Name -->
                    <TextBlock Text="ZenDesk"
               Foreground="White"
               FontSize="13"
               FontWeight="Bold"
               VerticalAlignment="Center"/>

                </StackPanel>

                <Button Width="40" Height="32"
        HorizontalAlignment="Right"
        Click="CloseButton_Click"
        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#AAAAAA"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="13"/>
                            <!-- ✅ Override the entire template to prevent default hover -->
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0">
                                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#e81123"/>
                                                <Setter Property="Foreground"
                                        Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#c0392b"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="✕"
               Foreground="{Binding Foreground,
               RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>

            </Grid>

            <!-- Main content -->
            <Grid Margin="14,40,14,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="200"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Preview Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,6">
                    <TextBlock Text="Preview" FontSize="16"
                               FontWeight="Bold" Foreground="#F2F2F2"/>
                    <TextBlock Text="How others will see your screen"
                               FontSize="12" Foreground="#949494"/>
                    
                </StackPanel>

                <!-- Live Preview -->
                <Border Grid.Row="1" Background="#111111"
                        CornerRadius="6" Margin="0,0,0,4">
                    <Image x:Name="PreviewImage" Stretch="Uniform"
                           Margin="4" Source="{Binding PreviewFrame}"/>
                </Border>

                <!-- Monitor Switcher -->
                <ItemsControl Grid.Row="2" x:Name="MonitorSwitcher"
                              Margin="0,4,0,8" Visibility="Collapsed">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!-- Hide Applications Header -->
                <StackPanel Grid.Row="3" Margin="0,0,0,6">
                    <TextBlock Text="Hide applications" FontSize="16"
                               FontWeight="Bold" Foreground="#F2F2F2"/>
                    <TextBlock Text="Select the windows to hide"
                               FontSize="12" Foreground="#949494"/>
                </StackPanel>

                <!-- Window List -->
                <ScrollViewer Grid.Row="4">
                    <ItemsControl ItemsSource="{Binding Windows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2,0,2" MinHeight="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22"/>
                                        <!-- Hide checkbox -->
                                        <ColumnDefinition Width="22"/>
                                        <!-- Icon -->
                                        <ColumnDefinition Width="*"/>
                                        <!-- Title -->
                                        <ColumnDefinition Width="48"/>
                                        <!-- Click-through -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Hide Checkbox -->
                                    <CheckBox Grid.Column="0"
                              IsChecked="{Binding IsHidden, Mode=TwoWay}"
                              Checked="WindowCheckbox_Changed"
                              Unchecked="WindowCheckbox_Changed"
                              Tag="{Binding}"
                              VerticalAlignment="Center"
                              Margin="0"/>

                                    <!-- App Icon -->
                                    <Image Grid.Column="1"
                           Source="{Binding Icon}"
                           Width="16" Height="16"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>

                                    <!-- Window Title -->
                                    <TextBlock Grid.Column="2"
                               Text="{Binding Title}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Margin="6,0,4,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                                        <Setter Property="Foreground" Value="#666666"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Click-Through Checkbox -->
                                    <CheckBox Grid.Column="3"
                              IsChecked="{Binding IsClickThrough, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center">
                                        <CheckBox.Content>
                                            <TextBlock FontSize="12">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text"       Value="🖱✕"/>
                                                        <Setter Property="Foreground" Value="#555555"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsClickThrough}" Value="True">
                                                                <Setter Property="Text"       Value="🖱✕"/>
                                                                <Setter Property="Foreground" Value="#f38ba8"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </CheckBox.Content>
                                        <CheckBox.Style>
                                            <Style TargetType="CheckBox">
                                                <Setter Property="Margin"                  Value="0"/>
                                                <Setter Property="Padding"                 Value="2,0,0,0"/>
                                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            </Style>
                                        </CheckBox.Style>
                                    </CheckBox>

                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>



                <!-- Advanced Settings -->
                <Expander Grid.Row="5" Header="Advanced settings"
                          Foreground="#AAAAAA" Margin="0,10,0,0">
                    <StackPanel Margin="14,8,0,0">
                        <CheckBox Content="Hide from Alt+Tab and Taskbar"
                                  IsChecked="{Binding HideFromTaskbar, Mode=TwoWay}"/>
                        <CheckBox Content="Show desktop preview"
                                  IsChecked="{Binding ShowDesktopPreview, Mode=TwoWay}"/>
                        <CheckBox Content="Make hidden windows transparent"
                                  IsChecked="{Binding EnableTransparency, Mode=TwoWay}"
                                  Margin="0,6,0,2"/>
                        <StackPanel Margin="0,4,0,0"
                                    IsEnabled="{Binding EnableTransparency}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock Text="Transparency amount:"
                                           FontSize="11" Foreground="#AAAAAA"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TransparencyPercent, StringFormat={}{0}%}"
                                           FontSize="11" Foreground="#CCCCCC"
                                           Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Slider Minimum="10" Maximum="90"
                                    Value="{Binding TransparencyAmount, Mode=TwoWay}"
                                    TickFrequency="10" IsSnapToTickEnabled="True"
                                    Foreground="#AAAAAA"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Low"  FontSize="10" Foreground="#666"/>
                                <TextBlock Text="High" FontSize="10" Foreground="#666"
                                           Margin="220,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Expander>
            </Grid>
        </Grid>

        <!-- ── UNFOCUSED VIEW ── -->
        <Grid x:Name="MiniView"
              Visibility="Collapsed"
              Background="#1E1E1E"
              MouseLeftButtonDown="MiniView_Click">
            <TextBlock Text=":)"
                       FontSize="18"
                       Foreground="#444444"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>

    </Grid>
</Window>
